{
    "name": "lmu-telemetry-lab",
    "version": "1.5.0",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.lmu.telemetry.lab",
        "productName": "SIM Telemetry Lab",
        "directories": {
            "output": "../dist-electron"
        },
        "icon": "build/icon.png",
        "extraResources": [
            {
                "from": "../dist/lmu-telemetry-backend",
                "to": "backend-dist/lmu-telemetry-backend",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true
        },
        "mac": {
            "target": [
                "dmg",
                "dir"
            ],
            "category": "public.app-category.utilities",
            "icon": "build/icon.png",
            "identity": null
        }
    },
    "devDependencies": {
        "electron": "^31.0.0",
        "electron-builder": "^24.13.3"
    }
}